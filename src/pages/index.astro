---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SpotCard from '../components/SpotCard.astro';
import WorkCard from '../components/WorkCard.astro';
import { PREFECTURES, sortPrefectures } from '../utils/constants';

const allSpots = await getCollection('spots');
const uniqueWorksCount = new Set(allSpots.map(s => s.data.title)).size;
const animeSpots = allSpots.filter(s => (Array.isArray(s.data.genre) ? s.data.genre.includes("anime") : s.data.genre === "anime"));
const dramaSpots = allSpots.filter(s => (Array.isArray(s.data.genre) ? s.data.genre.includes("drama") : s.data.genre === "drama"));
const movieSpots = allSpots.filter(s => (Array.isArray(s.data.genre) ? s.data.genre.includes("movie") : s.data.genre === "movie"));
const featuredSpots = allSpots.filter(s => s.data.featured).slice(0, 8);

// 作品ごとにグループ化する関数
const groupByWork = (spots: CollectionEntry<'spots'>[]) => {
  const worksMap = new Map();
  spots.forEach(spot => {
    const title = spot.data.title;
    if (!worksMap.has(title)) {
      // スラッグ作成（作品名から）
      const slug = title
        .replace(/[。、！？！？『』]/g, '')
        .trim()
        .toLowerCase()
        .replace(/\s+/g, '-');
        
      worksMap.set(title, {
        title,
        genre: spot.data.genre,
        image: spot.data.officialImage || spot.data.image || '/images/placeholder.jpg',
        spotCount: 0,
        slug,
      });
    }
    worksMap.get(title).spotCount++;
  });
  return Array.from(worksMap.values());
};

const animeWorks = groupByWork(animeSpots);
const dramaWorks = groupByWork(dramaSpots);
const movieWorks = groupByWork(movieSpots);

const prefectures = sortPrefectures([...new Set(allSpots.map(s => s.data.prefecture))]);
---

<BaseLayout title="日本全国の聖地を旅しよう" description="アニメ・ドラマ・映画の聖地を都道府県別・ジャンル別で横断検索。日本全国の聖地巡礼スポットをご紹介します。">
  <Header />

  <!-- Seichi Junrei no Ki: Simplified Japanese Modern Hero -->
  <section class="relative min-h-[60vh] flex flex-col justify-center bg-kinari overflow-hidden pt-24 pb-8">
    <!-- Wafu textures and accents -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/pinstriped-suit.png');"></div>
    <div class="absolute top-10 right-[10%] w-[300px] h-[300px] bg-accent/5 rounded-full blur-[100px] pointer-events-none"></div>
    
    <div id="sakura-container" class="absolute inset-0 pointer-events-none z-20"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 mb-12">
      <!-- Left: Vertical Title & Branding -->
      <div class="lg:col-span-1 hidden lg:flex flex-col items-center justify-center border-x border-navy/5 px-4 h-fit self-center">
        <div class="[writing-mode:vertical-rl] text-navy/30 font-serif text-[10px] font-black tracking-[0.5em] uppercase whitespace-nowrap">
          The Journey of Stories
        </div>
      </div>

      <div class="lg:col-span-7 flex flex-col justify-center text-center lg:text-left">
        <div class="flex flex-col lg:flex-row lg:items-end gap-6 mb-8">
          <h1 class="font-serif text-6xl md:text-8xl font-black text-navy leading-none tracking-tighter">
            聖地巡礼<br/>
            <span class="text-accent">ノ記</span>
          </h1>
          <div class="[writing-mode:vertical-rl] hidden lg:block text-navy font-serif text-lg font-black border-r-2 border-accent pr-4 leading-tight">
            あの日の情景、<br/>今の現実。
          </div>
        </div>
        
        <p class="text-navy/60 text-base md:text-lg font-medium mb-0 max-w-lg mx-auto lg:mx-0 leading-relaxed font-serif">
          物語の跡を巡り、その場所が持つ真実の姿をアーカイブ。<br class="hidden md:block"/>一歩踏み出せば、そこは作品の世界。
        </p>
      </div>

      <!-- Right: Floating Visual Frame (Compact) -->
      <div class="lg:col-span-4 hidden lg:flex flex-col justify-center items-end relative">
        <div class="relative w-full max-w-[280px] aspect-[4/5] overflow-hidden shadow-edge border-[8px] border-white group">
          {featuredSpots.length > 0 && (
            <img
              src={featuredSpots[0].data.image || featuredSpots[0].data.officialImage}
              alt={featuredSpots[0].data.title}
              class="w-full h-full object-cover grayscale-[0.3] contrast-[1.1] transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105"
            />
          )}
          <div class="absolute inset-0 border border-black/5"></div>
        </div>
        <!-- Decorative Seal -->
        <div class="absolute -bottom-4 -right-4 w-16 h-16 bg-accent flex items-center justify-center text-white font-serif text-xl font-black shadow-lg">
          巡
        </div>
      </div>
    </div>

    <!-- Emaki (Handscroll) style Auto-Flowing Marquee -->
    <div class="w-full bg-white border-y border-navy/5 py-8 relative overflow-hidden group">
      <!-- Paper texture overlay -->
      <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/handmade-paper.png');"></div>
      
      <div class="flex animate-marquee whitespace-nowrap gap-10 hover:[animation-play-state:paused]">
        {[...allSpots, ...allSpots].slice(0, 15).map((spot) => (
          <a href={`/spots/${spot.slug}`} class="inline-flex flex-col gap-3 w-56 shrink-0 group/item">
            <div class="relative aspect-video overflow-hidden border border-navy/10">
              <img src={spot.data.image || spot.data.officialImage} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover/item:scale-110"/>
              <div class="absolute inset-0 bg-navy/20 opacity-0 group-hover/item:opacity-100 transition-opacity flex items-center justify-center">
                 <span class="text-white font-serif text-[10px] font-black border border-white px-3 py-1.5">参拝</span>
              </div>
            </div>
            <div class="flex justify-between items-start font-serif">
              <div>
                <p class="text-[8px] font-black text-accent tracking-widest uppercase mb-0.5">{spot.data.prefecture}</p>
                <p class="text-xs font-black text-navy transition-colors group-hover/item:text-accent truncate w-40">{spot.data.spotName}</p>
              </div>
              <div class="text-[7px] text-navy/20 [writing-mode:vertical-rl] leading-none">物語之頁</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>)}

  {/* Netflix-style: 注目の聖地 (Featured) */}
  <section class="pt-6 pb-2 px-4 max-w-7xl mx-auto w-full max-w-[100vw] overflow-hidden">
    <div class="flex items-end justify-between mb-2">
      <div>
        <div class="text-accent text-[10px] font-black uppercase tracking-[0.3em] mb-2">Featured selection</div>
        <h2 class="font-display text-3xl font-black text-navy flex items-center gap-4">
          <div class="p-2 bg-accent/5 rounded-xl text-accent">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
          </div>
          注目の聖地
        </h2>
      </div>
      <a href="/spots" class="group flex items-center gap-2 text-xs font-black uppercase tracking-widest text-gray-400 hover:text-accent transition-colors pb-1 border-b border-transparent hover:border-accent">
        もっと見る
        <svg class="w-3 h-3 transform transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    <div class="scroll-row flex gap-4 overflow-x-auto pt-4 pb-4 snap-x snap-mandatory scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0">
      {featuredSpots.map((spot) => (
        <div class="snap-start flex-shrink-0 w-[200px] sm:w-[240px]">
          <SpotCard spot={spot} />
        </div>
      ))}
    </div>
  </section>

  {/* Netflix-style: アニメ聖地 (Works) */}
  <section class="pt-6 pb-2 px-4 max-w-7xl mx-auto border-t border-gray-100/50 w-full max-w-[100vw] overflow-hidden">
    <div class="flex items-end justify-between mb-2">
      <div>
        <div class="text-purple-600 text-[10px] font-black uppercase tracking-[0.3em] mb-2">Pop culture & Art</div>
        <h2 class="font-display text-3xl font-black text-navy flex items-center gap-4">
          <div class="p-2 bg-purple-50 rounded-xl text-purple-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          アニメ作品別
        </h2>
      </div>
      <a href="/genre/anime" class="group flex items-center gap-2 text-xs font-black uppercase tracking-widest text-gray-400 hover:text-purple-600 transition-colors pb-1 border-b border-transparent hover:border-purple-600">
        もっと見る
        <svg class="w-3 h-3 transform transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    <div class="scroll-row flex gap-4 overflow-x-auto pt-4 pb-4 snap-x snap-mandatory scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0">
      {animeWorks.map((work) => (
        <div class="snap-start flex-none w-[180px] sm:w-[220px]">
          <WorkCard work={work} />
        </div>
      ))}
    </div>
  </section>

  {/* Netflix-style: ドラマ聖地 (Works) */}
  <section class="pt-6 pb-2 px-4 max-w-7xl mx-auto border-t border-gray-100/50 w-full max-w-[100vw] overflow-hidden">
    <div class="flex items-end justify-between mb-2">
      <div>
        <div class="text-blue-600 text-[10px] font-black uppercase tracking-[0.3em] mb-2">Lifestyle & Romance</div>
        <h2 class="font-display text-3xl font-black text-navy flex items-center gap-4">
          <div class="p-2 bg-blue-50 rounded-xl text-blue-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          ドラマ作品別
        </h2>
      </div>
      <a href="/genre/drama" class="group flex items-center gap-2 text-xs font-black uppercase tracking-widest text-gray-400 hover:text-blue-600 transition-colors pb-1 border-b border-transparent hover:border-blue-600">
        もっと見る
        <svg class="w-3 h-3 transform transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    <div class="scroll-row flex gap-4 overflow-x-auto pt-4 pb-4 snap-x snap-mandatory scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0">
      {dramaWorks.map((work) => (
        <div class="snap-start flex-none w-[180px] sm:w-[220px]">
          <WorkCard work={work} />
        </div>
      ))}
    </div>
  </section>

  {/* Netflix-style: 映画聖地 (Works) */}
  <section class="pt-6 pb-2 px-4 max-w-7xl mx-auto border-t border-gray-100/50 w-full max-w-[100vw] overflow-hidden">
    <div class="flex items-end justify-between mb-2">
      <div>
        <div class="text-amber-600 text-[10px] font-black uppercase tracking-[0.3em] mb-2">Cinematic Stories</div>
        <h2 class="font-display text-3xl font-black text-navy flex items-center gap-4">
          <div class="p-2 bg-amber-50 rounded-xl text-amber-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/>
            </svg>
          </div>
          映画作品別
        </h2>
      </div>
      <a href="/genre/movie" class="group flex items-center gap-2 text-xs font-black uppercase tracking-widest text-gray-400 hover:text-amber-600 transition-colors pb-1 border-b border-transparent hover:border-amber-600">
        もっと見る
        <svg class="w-3 h-3 transform transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    <div class="scroll-row flex gap-4 overflow-x-auto pt-4 pb-4 snap-x snap-mandatory scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0">
      {movieWorks.map((work) => (
        <div class="snap-start flex-none w-[180px] sm:w-[220px]">
          <WorkCard work={work} />
        </div>
      ))}
    </div>
  </section>

  {/* Prefecture CTA: Optimized for Mobile */}
  <section class="pt-6 pb-2 px-4 max-w-7xl mx-auto w-full max-w-[100vw] overflow-hidden">
    <div class="bg-navy rounded-[40px] p-8 sm:p-16 text-white text-center relative overflow-hidden shadow-3xl">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"></div>
      <div class="relative z-10">
        <div class="text-accent text-[10px] font-black uppercase tracking-[0.4em] mb-6">Location search</div>
        <h2 class="font-display text-4xl sm:text-5xl font-black mb-6">都道府県から探す</h2>
        <p class="text-white/60 text-lg mb-12 max-w-xl mx-auto leading-relaxed">旅先の空気に触れながら、物語の記憶を辿る。<br class="hidden sm:block"/>いつもの旅行を、特別な物語への旅に。</p>
        <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
          {prefectures.slice(0, 16).map((pref) => (
            <a
              href={`/prefecture/${encodeURIComponent(pref)}`}
              class="px-6 py-3 bg-white/5 hover:bg-white text-white hover:text-navy rounded-2xl text-sm font-bold transition-all duration-300 border border-white/10 hover:border-white shadow-lg"
            >
              {pref}
            </a>
          ))}
          <a href="/spots" class="px-8 py-3 bg-accent text-white rounded-2xl text-sm font-black hover:bg-accent-dark transition-all duration-300 shadow-xl tracking-widest uppercase">
            All Prefectures
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  
  .scroll-row {
    scroll-padding-left: 1rem;
    -webkit-overflow-scrolling: touch;
  }

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up { animation: fadeInUp 1s ease-out forwards; }
  .animate-fade-in { animation: fadeIn 1.5s ease-out forwards; }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes bounceSlow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-bounce-slow { animation: bounceSlow 4s ease-in-out infinite; }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-100% - 1.5rem)); }
  }
  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
  @keyframes sakuraFall {
    0% { transform: translateY(0) rotate(0deg) translateX(0); }
    100% { transform: translateY(100vh) rotate(360deg) translateX(50px); }
  }
</style>

<script>
  // Sakura falling animation (Optimized: Using CSS shapes or small SVGs instead of emojis)
  const container = document.getElementById('sakura-container');
  if (container) {
    for (let i = 0; i < 20; i++) {
      const petal = document.createElement('div');
      // Create a small petal shape using CSS
      petal.style.cssText = `
        position: absolute;
        left: ${Math.random() * 100}%;
        top: -20px;
        width: ${Math.random() * 6 + 4}px;
        height: ${Math.random() * 8 + 6}px;
        background: ${Math.random() > 0.5 ? '#FFD1DC' : '#FFB7C5'};
        border-radius: 50% 50% 50% 50% / 80% 80% 20% 20%;
        opacity: ${Math.random() * 0.6 + 0.2};
        animation: sakuraFall ${Math.random() * 10 + 7}s linear ${Math.random() * 10}s infinite;
        pointer-events: none;
      `;
      container.appendChild(petal);
    }
  }
</script>
