---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import MapView from '../../components/MapView.astro';
import SpotCard from '../../components/SpotCard.astro';

export async function getStaticPaths() {
  const spots = await getCollection('spots');
  return spots.map((spot) => ({
    params: { slug: spot.slug },
    props: { spot },
  }));
}

interface Props {
  spot: CollectionEntry<'spots'>;
}

const { spot } = Astro.props;
const { Content } = await spot.render();

const { title, spotName, genre, prefecture, address, lat, lng, image, imageCredit, imageCreditUrl, officialImage, officialImageCredit, episode, description } = spot.data;

const genres = Array.isArray(genre) ? genre : [genre];
const genreLabels = genres.map(g => ({ anime: 'アニメ', drama: 'ドラマ', movie: '映画' }[g]));
const genreLabel = genreLabels.join(' / ');
const genreColorMap = { anime: 'bg-purple-600 text-white', drama: 'bg-blue-600 text-white', movie: 'bg-amber-600 text-white' };
const genreColor = genreColorMap[genres[0] as keyof typeof genreColorMap];
const workSlug = title.replace(/[。、！？！？『』]/g, '').trim().toLowerCase().replace(/\s+/g, '-');

const displayImage = image || officialImage || '/images/placeholder.jpg';

const allSpots = await getCollection('spots');
const related = allSpots.filter(s => s.slug !== spot.slug && ((Array.isArray(s.data.genre) ? s.data.genre.some(g => genres.includes(g)) : genres.includes(s.data.genre as string)) || s.data.prefecture === prefecture)).slice(0, 3);
---

<BaseLayout
  title={`${title} 聖地 ${spotName}`}
  description={description}
  ogImage={displayImage}
>
  <Header />

  <main class="max-w-5xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-10">
      <a href="/" class="hover:text-navy transition-colors">ホーム</a>
      <span>/</span>
      <a href="/spots" class="hover:text-navy transition-colors">スポット一覧</a>
      <span>/</span>
      <span class="text-navy font-medium truncate">{spotName}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Hero Image -->
        <div class="relative rounded-3xl overflow-hidden mb-8 shadow-2xl aspect-video bg-gray-900 group">
          <img
            src={displayImage}
            alt={`${title}の聖地・${spotName}`}
            class="w-full h-full object-cover"
            referrerpolicy="no-referrer"
            onerror="this.src='/images/placeholder.jpg'"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute top-6 left-6 flex gap-2 flex-wrap">
            {genres.map((g: string) => {
              const localLabel = { anime: 'アニメ', drama: 'ドラマ', movie: '映画' }[g as keyof typeof genreColorMap];
              const localColor = genreColorMap[g as keyof typeof genreColorMap];
              return (
                <span class={`px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest ${localColor} shadow-lg text-white`}>
                  {localLabel}
                </span>
              );
            })}
          </div>
          
          {image === undefined && officialImage && (
            <div class="absolute bottom-6 left-6 right-6">
               <span class="bg-white/20 backdrop-blur-md text-white text-[10px] px-2 py-1 rounded uppercase tracking-tighter">Official Artwork Placeholder</span>
            </div>
          )}
        </div>

        <!-- Image Credit -->
        {imageCredit && (
          <p class="text-[10px] text-gray-400 mb-8 flex items-center gap-1.5 px-2">
            <svg class="w-3 h-3 flex-shrink-0 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="uppercase tracking-widest">画像提供:</span>
            {(() => {
              let shortCredit = imageCredit;
              let provider = "";
              if (imageCredit.includes("Wikimedia Commons")) {
                provider = "Wikimedia Commons";
              } else if (imageCredit.includes("Mapillary")) {
                provider = "Mapillary";
              }
              
              if (provider) {
                const author = imageCredit.split(",")[0].trim();
                shortCredit = author !== provider ? `${author} (${provider})` : provider;
              }
              
              return imageCreditUrl ? (
                <a href={imageCreditUrl} target="_blank" rel="noopener noreferrer" class="hover:text-navy underline transition-colors">
                  {shortCredit}
                </a>
              ) : (
                <span>{shortCredit}</span>
              );
            })()}
          </p>
        )}

        <!-- Title Block -->
        <div class="mb-12">
          <p class="text-accent font-bold text-sm mb-2 tracking-wide uppercase">『{title}』</p>
          <h1 class="font-display text-4xl sm:text-5xl font-black text-navy mb-6 tracking-tight leading-tight">{spotName}</h1>
          <div class="flex flex-wrap gap-6 text-sm text-gray-500">
            <span class="flex items-center gap-2">
              <div class="p-1.5 bg-gray-100 rounded-lg text-navy">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <span class="font-medium text-gray-700">{prefecture} · {address}</span>
            </span>
            {episode && (
              <span class="flex items-center gap-2">
                <div class="p-1.5 bg-gray-100 rounded-lg text-navy">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                  </svg>
                </div>
                <span class="font-medium text-gray-700">{episode}</span>
              </span>
            )}
          </div>
        </div>

        <!-- Article Content -->
        <div class="prose prose-lg prose-navy max-w-none prose-headings:font-display prose-headings:font-bold prose-headings:text-navy prose-p:text-gray-600 prose-p:leading-loose prose-li:text-gray-600 prose-a:text-accent prose-img:rounded-3xl prose-img:shadow-xl prose-blockquote:border-accent prose-blockquote:bg-gray-50 prose-blockquote:p-6 prose-blockquote:rounded-2xl">
          <Content />
        </div>

        <!-- Official Visual / Poster Section (Improved Design) -->
        {officialImage && (
          <div class="mt-20 overflow-hidden rounded-3xl bg-navy text-white shadow-2xl transition-transform">
            <div class="relative p-1 px-1">
               <!-- Background Blur Poster -->
               <div class="absolute inset-0 opacity-20 blur-2xl scale-110">
                 <img src={officialImage} class="w-full h-full object-cover" alt="" />
               </div>
               
               <div class="relative z-10 flex flex-col md:flex-row items-center gap-8 p-8 md:p-12">
                 <!-- Image Wrapper with link and hover scale -->
                 <a 
                   href={`/genre/${genres[0]}/${workSlug}`}
                   class="w-full md:w-1/3 max-w-[280px] flex-shrink-0 shadow-2xl transition-transform duration-500 hover:scale-105 block group"
                 >
                   <div class="rounded-xl overflow-hidden bg-black/20 backdrop-blur-sm border border-white/10">
                     <img
                       src={officialImage}
                       alt={`${title} 公式ビジュアル`}
                       class="w-full h-auto object-contain max-h-[400px]"
                       referrerpolicy="no-referrer"
                     />
                   </div>
                 </a>
                 
                 <div class="flex-1 text-center md:text-left">
                   <div class="inline-block px-3 py-1 rounded-full bg-white/10 text-[10px] font-bold tracking-widest uppercase mb-4 border border-white/20">Official Visual</div>
                   <h2 class="font-display text-3xl md:text-4xl font-black mb-4 leading-tight">{title}</h2>
                   <p class="text-white/70 text-lg leading-relaxed mb-6">{description}</p>
                   {officialImageCredit && (
                     <p class="text-[10px] text-white/40 italic uppercase tracking-widest">{officialImageCredit}</p>
                   )}
                 </div>
               </div>
            </div>
          </div>
        )}

        <!-- Map -->
        <div class="mt-16">
          <div class="flex items-center gap-4 mb-8">
            <div class="p-3 bg-navy text-white rounded-2xl shadow-lg">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h2 class="font-display text-3xl font-black text-navy tracking-tight">周辺地図</h2>
          </div>
          <div class="rounded-3xl overflow-hidden shadow-2xl border border-gray-100">
            <MapView lat={lat} lng={lng} spotName={spotName} title={title} />
          </div>
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${lat},${lng}`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2.5 text-xs font-black uppercase tracking-widest text-navy hover:text-accent transition-all duration-300"
          >
            Open in Google Maps
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Info Card -->
        <div class="bg-white rounded-2xl shadow-card p-6 sticky top-24">
          <h2 class="font-semibold text-navy mb-4 text-sm uppercase tracking-wider">スポット情報</h2>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-gray-400 text-xs mb-0.5">作品名</dt>
              <dd class="font-medium text-gray-800">『{title}』</dd>
            </div>
            <div>
              <dt class="text-gray-400 text-xs mb-0.5">ジャンル</dt>
              <dd class="flex flex-wrap gap-1.5">
                {genres.map((g: string) => {
                  const localLabel = { anime: 'アニメ', drama: 'ドラマ', movie: '映画' }[g as keyof typeof genreColorMap];
                  const localColor = genreColorMap[g as keyof typeof genreColorMap];
                  return (
                    <a href={`/genre/${g}`} class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold ${localColor} hover:opacity-80 transition-opacity`}>
                      {localLabel}
                    </a>
                  );
                })}
              </dd>
            </div>
            <div>
              <dt class="text-gray-400 text-xs mb-0.5">場所名</dt>
              <dd class="font-medium text-gray-800">{spotName}</dd>
            </div>
            <div>
              <dt class="text-gray-400 text-xs mb-0.5">都道府県</dt>
              <dd>
                <a href={`/prefecture/${encodeURIComponent(prefecture)}`} class="text-navy font-medium hover:text-accent transition-colors">
                  {prefecture}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-gray-400 text-xs mb-0.5">住所</dt>
              <dd class="text-gray-700">{address}</dd>
            </div>
            {episode && (
              <div>
                <dt class="text-gray-400 text-xs mb-0.5">登場エピソード</dt>
                <dd class="text-gray-700">{episode}</dd>
              </div>
            )}
            <div>
              <dt class="text-gray-400 text-xs mb-0.5">座標</dt>
              <dd class="text-gray-500 text-xs font-mono">{lat.toFixed(4)}, {lng.toFixed(4)}</dd>
            </div>
          </dl>

          <div class="mt-5 pt-5 border-t border-gray-100">
            <a
              href={`https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full flex items-center justify-center gap-2 bg-navy text-white py-3 rounded-xl text-sm font-semibold hover:bg-navy-dark transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
              </svg>
              ルート案内
            </a>
          </div>
        </div>
      </aside>
    </div>

    <!-- Related Spots -->
    {related.length > 0 && (
      <div class="mt-24">
        <div class="flex items-center justify-between mb-10">
          <h2 class="font-display text-3xl font-black text-navy tracking-tight">関連スポット</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          {related.map((s) => <SpotCard spot={s} />)}
        </div>
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  .prose-navy h2 { color: #1D3557; font-weight: 900; }
  .prose-navy h3 { color: #1D3557; font-weight: 800; }
  .prose p { margin-bottom: 2rem; }
</style>
