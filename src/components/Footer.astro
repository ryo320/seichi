---
import { sortPrefectures } from '../utils/constants';
---
<footer class="bg-navy text-white mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="max-w-xs transition-all">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-10 h-10 border-2 border-white/20 flex items-center justify-center transform rotate-45">
              <span class="font-serif text-xl font-black transform -rotate-45">記</span>
            </div>
            <span class="font-serif text-2xl font-black text-white tracking-widest leading-none">聖地巡礼ノ記</span>
          </div>
          <p class="text-gray-400 text-sm font-medium leading-relaxed mb-8 font-serif">
            あの日の情景、今の現実。作品の記憶を辿る、日本の聖地巡礼アーカイブ。
          </p>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-semibold mb-4 text-sm uppercase tracking-wider text-gray-400">ジャンル別</h3>
        <ul class="space-y-2">
          <li><a href="/genre/anime" class="text-gray-300 hover:text-white text-sm transition-colors">🎌 アニメ聖地</a></li>
          <li><a href="/genre/drama" class="text-gray-300 hover:text-white text-sm transition-colors">📺 ドラマ聖地</a></li>
          <li><a href="/genre/movie" class="text-gray-300 hover:text-white text-sm transition-colors">🎬 映画聖地</a></li>
          <li><a href="/spots" class="text-gray-300 hover:text-white text-sm transition-colors">📍 全スポット一覧</a></li>
        </ul>
      </div>

      <!-- About -->
      <div>
        <h3 class="font-semibold mb-4 text-sm uppercase tracking-wider text-gray-400">エリア別</h3>
        <div class="flex flex-wrap gap-2">
          {sortPrefectures(['東京都', '神奈川県', '京都府', '大阪府', '岐阜県', '宮城県', '岩手県', '愛媛県']).map((pref) => (
            <a
              href={`/prefecture/${encodeURIComponent(pref)}`}
              class="px-2 py-1 bg-white/10 hover:bg-white/20 rounded text-xs text-gray-300 hover:text-white transition-colors"
            >
              {pref}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-white/10 text-center text-gray-500 text-xs">
      <p>© 2025 聖地巡礼ノ記. あの日の情景、今の現実。</p>
    </div>
  </div>
</footer>
