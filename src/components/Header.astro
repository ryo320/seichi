---
const navItems = [
  { label: 'ホーム', href: '/' },
  { label: 'スポット一覧', href: '/spots' },
  { label: '地図で探す', href: '/map' },
  { label: 'アニメ', href: '/genre/anime' },
  { label: 'ドラマ', href: '/genre/drama' },
  { label: '映画', href: '/genre/movie' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative">
          <div class="bg-navy text-white p-2 rounded-sm transform rotate-45 group-hover:bg-accent transition-all duration-500">
            <svg class="w-5 h-5 transform -rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </div>
          <div class="absolute -inset-1 border border-navy/10 rounded-sm transform rotate-45 group-hover:border-accent/10 transition-all duration-500"></div>
        </div>
        <div class="flex flex-col">
          <span class="font-serif text-2xl font-black text-navy tracking-tight leading-none mb-0.5">聖地巡礼ノ記</span>
          <span class="font-serif text-[9px] font-bold text-accent uppercase tracking-[0.4em] leading-none opacity-80">Seichi Junrei no Ki</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 ${
              currentPath === item.href
                ? 'bg-navy text-white'
                : 'text-gray-600 hover:bg-gray-100 hover:text-navy'
            }`}
          >
            {item.label}
          </a>
        ))}
        <a
          href="/spots"
          class="ml-2 px-4 py-2 bg-accent text-white rounded-full text-sm font-medium hover:bg-accent-dark transition-colors duration-200 shadow-sm"
        >
          全スポットを見る
        </a>
      </nav>

      <!-- Mobile Hamburger -->
      <button
        id="menu-toggle"
        class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
        aria-label="メニューを開く"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 py-4 space-y-1">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="block px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 hover:text-navy transition-colors"
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
