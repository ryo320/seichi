---
interface Props {
  prefectures: string[];
  currentGenre?: string;
  currentPrefecture?: string;
}
const { prefectures, currentGenre, currentPrefecture } = Astro.props;

const genres = [
  { value: '', label: '全ジャンル' },
  { value: 'anime', label: '🎌 アニメ' },
  { value: 'drama', label: '📺 ドラマ' },
  { value: 'movie', label: '🎬 映画' },
];
---

<div class="bg-white rounded-2xl shadow-card p-6 mb-8">
  <div class="flex flex-col sm:flex-row gap-6">
    <!-- Genre Filter -->
    <div class="flex-1">
      <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">ジャンル</label>
      <div class="flex flex-wrap gap-2" id="genre-filter">
        {genres.map((g) => (
          <button
            data-genre={g.value}
            class={`filter-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 border ${
              (currentGenre ?? '') === g.value
                ? 'bg-navy text-white border-navy'
                : 'bg-white text-gray-600 border-gray-200 hover:border-navy hover:text-navy'
            }`}
          >
            {g.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Prefecture Filter -->
    <div class="flex-1">
      <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">都道府県</label>
      <select
        id="prefecture-select"
        class="w-full px-4 py-2 rounded-xl border border-gray-200 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-navy focus:border-transparent bg-white appearance-none cursor-pointer"
      >
        <option value="">すべての都道府県</option>
        {prefectures.sort().map((pref) => (
          <option value={pref} selected={pref === currentPrefecture}>{pref}</option>
        ))}
      </select>
    </div>

    <!-- Search -->
    <div class="flex-1">
      <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">作品名・場所で検索</label>
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="例：京都、鬼滅..."
          class="w-full pl-10 pr-4 py-2 rounded-xl border border-gray-200 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-navy focus:border-transparent"
        />
        <svg class="absolute left-3 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Active count -->
  <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between">
    <p class="text-sm text-gray-500">
      <span id="spot-count" class="font-bold text-navy">0</span> 件のスポットが見つかりました
    </p>
    <button id="reset-filter" class="text-xs text-accent hover:text-accent-dark font-medium transition-colors">
      フィルターをリセット
    </button>
  </div>
</div>

<script>
  // FilterBar client-side logic
  let activeGenre = '';
  let activePrefecture = '';
  let searchQuery = '';

  const cards = document.querySelectorAll<HTMLElement>('[data-spot-card]');
  const countEl = document.getElementById('spot-count');

  function updateCount() {
    const visible = document.querySelectorAll('[data-spot-card]:not([hidden])').length;
    if (countEl) countEl.textContent = String(visible);
  }

  function applyFilters() {
    cards.forEach((card) => {
      const genre = card.dataset.genre ?? '';
      const prefecture = card.dataset.prefecture ?? '';
      const text = (card.dataset.text ?? '').toLowerCase();
      const q = searchQuery.toLowerCase();

      const matchGenre = !activeGenre || genre.split(',').includes(activeGenre);
      const matchPref = !activePrefecture || prefecture === activePrefecture;
      const matchSearch = !q || text.includes(q);

      card.hidden = !(matchGenre && matchPref && matchSearch);
    });
    updateCount();
  }

  // Genre buttons
  document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      activeGenre = btn.dataset.genre ?? '';
      document.querySelectorAll('.filter-btn').forEach((b) => {
        b.classList.remove('bg-navy', 'text-white', 'border-navy');
        b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
      });
      btn.classList.add('bg-navy', 'text-white', 'border-navy');
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
      applyFilters();
    });
  });

  // Prefecture select
  document.getElementById('prefecture-select')?.addEventListener('change', (e) => {
    activePrefecture = (e.target as HTMLSelectElement).value;
    applyFilters();
  });

  // Search
  document.getElementById('search-input')?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    applyFilters();
  });

  // Reset
  document.getElementById('reset-filter')?.addEventListener('click', () => {
    activeGenre = '';
    activePrefecture = '';
    searchQuery = '';
    (document.getElementById('prefecture-select') as HTMLSelectElement).value = '';
    (document.getElementById('search-input') as HTMLInputElement).value = '';
    document.querySelectorAll('.filter-btn').forEach((b, i) => {
      if (i === 0) {
        b.classList.add('bg-navy', 'text-white', 'border-navy');
        b.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
      } else {
        b.classList.remove('bg-navy', 'text-white', 'border-navy');
        b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
      }
    });
    applyFilters();
  });

  // Init count – DOMContentLoadedを待ってカードが全て描画されてからカウント
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateCount);
  } else {
    // 既にDOMが準備できている場合は次フレームで実行
    requestAnimationFrame(updateCount);
  }
</script>
