---
import type { CollectionEntry } from 'astro:content';

interface Props {
  spot: CollectionEntry<'spots'>;
}

const { spot } = Astro.props;
const { title, spotName, genre, prefecture, image, officialImage, description, episode } = spot.data;

const displayImage = image || officialImage || '/images/placeholder.jpg';

const genres = Array.isArray(genre) ? genre : [genre];
const genreLabels = genres.map(g => ({ anime: 'アニメ', drama: 'ドラマ', movie: '映画' }[g]));
const genreLabel = genreLabels.join(' / ');
const genreColorMap = {
  anime: 'bg-purple-600 text-white',
  drama: 'bg-blue-600 text-white',
  movie: 'bg-amber-600 text-white'
};
const genreColor = genreColorMap[genres[0] as keyof typeof genreColorMap];
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-hover transition-all duration-300 hover:-translate-y-2 hover:scale-[1.02] flex flex-col">
  <!-- Image -->
  <a href={`/spots/${spot.slug}`} class="relative block overflow-hidden aspect-[4/3]">
    <img
      src={displayImage}
      alt={`${title}の聖地・${spotName}`}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      loading="lazy"
      referrerpolicy="no-referrer"
      onerror="this.src='/images/placeholder.jpg'"
    />
    <!-- Dark overlay on hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/0 to-black/0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    <!-- Genre Badge -->
    <div class="absolute top-3 left-3 flex gap-1.5 flex-wrap">
      {genres.map((g: string) => {
        const localLabel = { anime: 'アニメ', drama: 'ドラマ', movie: '映画' }[g as keyof typeof genreColorMap];
        const localColor = genreColorMap[g as keyof typeof genreColorMap];
        return (
          <span class={`px-2.5 py-1 rounded-full text-xs font-semibold ${localColor} backdrop-blur-sm shadow-sm`}>
            {localLabel}
          </span>
        );
      })}
    </div>
    {/* Hover info overlay */}
    <div class="absolute bottom-0 left-0 right-0 p-3 text-white translate-y-1 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
      <p class="text-[10px] text-white/80 mb-0.5">『{title}』</p>
      <p class="font-bold text-xs">{spotName}</p>
    </div>
  </a>

  {/* Content */}
  <div class="p-3 flex flex-col flex-1">
    {/* Prefecture */}
    <div class="flex items-center gap-1 text-[10px] text-gray-400 mb-1.5">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <span>{prefecture}</span>
    </div>

    {/* Title */}
    <h3 class="font-bold text-navy text-sm leading-snug mb-0.5 group-hover:text-accent transition-colors">
      <a href={`/spots/${spot.slug}`}>{spotName}</a>
    </h3>
    <p class="text-[10px] text-accent font-medium mb-1.5">『{title}』</p>

    {/* Episode */}
    {episode && (
      <p class="text-[10px] text-gray-500 mb-2 flex items-start gap-1">
        <svg class="w-3 h-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        <span class="line-clamp-1">{episode}</span>
      </p>
    )}

    {/* Description */}
    <p class="text-xs text-gray-600 line-clamp-2 flex-1">{description}</p>

    {/* CTA */}
    <a
      href={`/spots/${spot.slug}`}
      class="mt-3 inline-flex items-center gap-1.5 text-xs font-semibold text-navy hover:text-accent transition-colors group/link"
    >
      <span>詳細を見る</span>
      <svg class="w-3.5 h-3.5 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>
